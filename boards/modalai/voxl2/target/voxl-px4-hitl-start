#!/bin/sh
# PX4 commands need the 'px4-' prefix in bash.
# (px4-alias.sh is expected to be in the PATH)
. px4-alias.sh

# Figure out what platform we are running on.
PLATFORM=`/usr/bin/voxl-platform 2> /dev/null`
RETURNCODE=$?
if [ $RETURNCODE -ne 0 ]; then
    # If we couldn't get the platform from the voxl-platform utility then check
    # /etc/version to see if there is an M0052 substring in the version string. If so,
    # then we assume that we are on M0052.
    VERSIONSTRING=$(</etc/version)
    M0052SUBSTRING="M0052"
    if [[ "$VERSIONSTRING" == *"$M0052SUBSTRING"* ]]; then
        PLATFORM="M0052"
    fi
fi

# We can only run on M0052, M0054, or M0104 so exit with error if that is not the case
if [ $PLATFORM = "M0052" ]; then
    /bin/echo "Running on M0052"
elif [ $PLATFORM = "M0054" ]; then
    /bin/echo "Running on M0054"
elif [ $PLATFORM = "M0104" ]; then
    /bin/echo "Running on M0104"
elif [ $PLATFORM = "M0197" ]; then
    /bin/echo "Running on M0197"
else
    /bin/echo "Error, cannot determine platform!"
    exit 0
fi

# Sleep a little here. A lot happens when the uorb and muorb start
# and we need to make sure that it all completes successfully to avoid
# any possible race conditions.
/bin/sleep 1

if [ ! -f /data/px4/param/hitl_parameters ]; then
   echo "[INFO] Setting default parameters for PX4 on voxl"
    . /etc/modalai/voxl-px4-hitl-set-default-parameters.config
   /bin/sync
else
    param select /data/px4/param/hitl_parameters
    param load
fi

# We do not change the following parameters but QGC will complain if they aren't
# being reported as "used" by px4. "Touching" them accomplishes that.
param touch SYS_AUTOCONFIG
param touch SDLOG_MODE

# Start logging and use timestamps for log files when possible.
# Add the "-e" option to start logging immediately. Default is
# to log only when armed. Caution must be used with the "-e" option
# because if power is removed without stopping the logger gracefully then
# the log file may be corrupted.
logger start -e -t -b 200

/bin/sleep 1

# Start apps processor modules needed for data flow
dataman start
navigator start
load_mon start
vehicle_air_data_bridge start

# microdds_client not needed for HITL VFC -- all communication uses MAVLink + MPA
# microdds_client start -t udp -h 127.0.0.1 -p 8888

# ============================================================================
# CRITICAL: Start MAVLink FIRST to receive HIL messages from Gazebo
# This must happen before dsp_hitl and sensors to avoid MUORB race conditions.
# ============================================================================

# ============================================================================
# MAVLINK INSTANCES - Minimal configuration for HITL
# ============================================================================

# PRIMARY: HIL link to Gazebo - receives HIL_SENSOR/HIL_GPS, sends actuators
# Rate needs to be high enough for 200Hz actuator commands (~10KB/s)
mavlink start -x -u 14560 -o 14550 -r 50000 -p

# SECONDARY: Onboard link for voxl-mavlink-server (reduced for HITL)
mavlink start -x -u 14556 -o 14557 -r 5000 -n lo -m onboard

# TERTIARY: GCS forwarding (minimal for HITL)
mavlink start -x -u 14558 -o 14559 -r 2000 -n lo

# Wait for MAVLink to establish connection and start receiving HIL_SENSOR messages
/bin/sleep 1

# ============================================================================
# Start dsp_hitl BEFORE sensors module
# dsp_hitl subscribes to hil_sensor_imu and hil_sensor_mag_baro (from apps proc
# MavlinkReceiver via MUORB) and republishes as sensor_accel/sensor_gyro/
# sensor_mag/sensor_baro with fresh DSP timestamps.
# ============================================================================
qshell dsp_hitl start

# Wait for dsp_hitl to start publishing sensor topics
/bin/sleep 1

# ============================================================================
# NOW start sensors module on DSP - sensor topics should be available
# ============================================================================
# UNLESS RUNNING GZ WITH THE RC PLUGIN/MDOEL, MAKE SURE TO START THE RC MODULE YOU DESIRE FOR HIL
# qshell crsf_rc start -d 6 -b 420000 
# ============================================================================
qshell sensors start -h
qshell ekf2 start
qshell mc_pos_control start
qshell mc_att_control start
qshell mc_rate_control start
qshell mc_hover_thrust_estimator start
qshell mc_autotune_attitude_control start
qshell land_detector start multicopter
qshell manual_control start
qshell control_allocator start
qshell rc_update start
qshell commander start -h
qshell commander mode posctl
qshell load_mon start

# This is needed for altitude and position hold modes
qshell flight_mode_manager start

qshell pwm_out_sim start -m hil

/bin/sleep 1

# ============================================================================
# MINIMAL MAVLINK STREAMS FOR HITL
# Only enable what's strictly needed to reduce MUORB/DSP load
# ============================================================================

# REQUIRED: Actuator commands from DSP to Gazebo
mavlink stream -u 14560 -s HIL_ACTUATOR_CONTROLS -r 200

# DISABLE high-rate output streams that create unnecessary load
mavlink stream -u 14560 -s HIGHRES_IMU -r 0
mavlink stream -u 14560 -s SCALED_IMU -r 0
mavlink stream -u 14560 -s SCALED_IMU2 -r 0
mavlink stream -u 14560 -s SCALED_IMU3 -r 0
# mavlink stream -u 14560 -s RAW_IMU -r 0

# Keep minimal telemetry for GCS (low rates)
mavlink stream -u 14556 -s ATTITUDE -r 10
mavlink stream -u 14556 -s ATTITUDE_QUATERNION -r 10
mavlink stream -u 14556 -s GLOBAL_POSITION_INT -r 5
mavlink stream -u 14556 -s LOCAL_POSITION_NED -r 5

mavlink boot_complete

# ============================================================================
# BRIDGES - Only start what's strictly needed for HITL
# REMOVED: sensor_baro_bridge (dsp_hitl handles baro)
# REMOVED: vehicle_air_data_bridge (redundant with dsp_hitl baro)
# REMOVED: crsf_bridge (RC not needed for HITL sim)
# REMOVED: mavlink_odometry_bridge (not needed for basic HITL)
# ============================================================================

vfc_logger start
# vehicle_local_position_bridge start  # Only if apps proc needs position
