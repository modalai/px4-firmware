# Param setting and declaring file
# Default parameters for HITL simulation with x500 quadcopter in Gazebo

param select /data/px4/param/hitl_parameters

# Sys config parameters
param set SYS_AUTOSTART 1001
param set SYS_HITL 1

# Make sure we are running at 800Hz on IMU
param set IMU_GYRO_RATEMAX 800

# Control allocation -- x500 quadcopter geometry
# Rotor positions in PX4 body frame (FRD), converted from x500/model.sdf (FLU)
# FLU→FRD: X unchanged, Y negated, Z negated
# Rotor 0: front-right, CCW  (FRD: px=+0.174, py=+0.174)
# Rotor 1: back-left,   CCW  (FRD: px=-0.174, py=-0.174)
# Rotor 2: front-left,  CW   (FRD: px=+0.174, py=-0.174)
# Rotor 3: back-right,  CW   (FRD: px=-0.174, py=+0.174)
param set CA_AIRFRAME 0
param set CA_ROTOR_COUNT 4
param set CA_ROTOR0_PX 0.174
param set CA_ROTOR0_PY 0.174
param set CA_ROTOR0_KM 0.05
param set CA_ROTOR1_PX -0.174
param set CA_ROTOR1_PY -0.174
param set CA_ROTOR1_KM 0.05
param set CA_ROTOR2_PX 0.174
param set CA_ROTOR2_PY -0.174
param set CA_ROTOR2_KM -0.05
param set CA_ROTOR3_PX -0.174
param set CA_ROTOR3_PY 0.174
param set CA_ROTOR3_KM -0.05

# Sensor calibration -- identity for simulated sensors (HITL)
# Device IDs must match dsp_hitl: accel/gyro=1310988 (DRV_IMU_DEVTYPE_SIM), mag=197388 (DRV_MAG_DEVTYPE_MAGSIM)
# Accelerometer: zero offsets, unity scale
param set CAL_ACC0_ID 1310988
param set CAL_ACC0_PRIO 50
param set CAL_ACC0_XOFF 0.0
param set CAL_ACC0_XSCALE 1.0
param set CAL_ACC0_YOFF 0.0
param set CAL_ACC0_YSCALE 1.0
param set CAL_ACC0_ZOFF 0.0
param set CAL_ACC0_ZSCALE 1.0
param set CAL_ACC1_PRIO 50
param set CAL_ACC2_PRIO 50
param set CAL_ACC3_PRIO 50

# Gyroscope: zero offsets
param set CAL_GYRO0_ID 1310988
param set CAL_GYRO0_PRIO 50
param set CAL_GYRO0_XOFF 0.0
param set CAL_GYRO0_YOFF 0.0
param set CAL_GYRO0_ZOFF 0.0
param set CAL_GYRO1_PRIO 50
param set CAL_GYRO2_PRIO 50
param set CAL_GYRO3_PRIO 50

# Magnetometer: zero offsets, unity scale, no off-diagonal
param set CAL_MAG0_ID 197388
param set CAL_MAG0_PRIO 75
param set CAL_MAG0_ROT 0
param set CAL_MAG0_XODIAG 0.0
param set CAL_MAG0_XOFF 0.0
param set CAL_MAG0_XSCALE 1.0
param set CAL_MAG0_YODIAG 0.0
param set CAL_MAG0_YOFF 0.0
param set CAL_MAG0_YSCALE 1.0
param set CAL_MAG0_ZODIAG 0.0
param set CAL_MAG0_ZOFF 0.0
param set CAL_MAG0_ZSCALE 1.0
param set CAL_MAG1_PRIO 50
param set CAL_MAG2_PRIO 50
param set CAL_MAG3_PRIO 50

# Airspeed calibration (not used but set clean defaults)
param set CAL_AIR_CMODEL 0
param set CAL_AIR_TUBED_MM 1.5
param set CAL_AIR_TUBELEN 0.2

# Commander parameters
param set COM_CPU_MAX 0
param set COM_DISARM_PRFLT -1
param set COM_RC_IN_MODE 0      # RC Transmitter only - accept RC_CHANNELS_OVERRIDE as SOURCE_RC
param set NAV_RCL_ACT 0          # Disabled - no action on RC loss (required for HITL without RC)
param set COM_RCL_EXCEPT 4       # Exception for HITL mode
param set NAV_DLL_ACT 0          # No action on datalink loss
param set COM_FLIGHT_UUID 15
param set MAV_RC_BRIDGE 1

# EKF2 parameters -- IMU at origin for simulation
param set EKF2_ABL_LIM 0.8
param set EKF2_EV_DELAY 5.0
param set EKF2_IMU_POS_X 0.0
param set EKF2_IMU_POS_Y 0.0
param set EKF2_IMU_POS_Z 0.0
param set EKF2_MAG_DECL 0.0

# EKF2 HITL-specific parameters
param set EKF2_GPS_CHECK 0       # Disable GPS quality checks for HITL
param set EKF2_REQ_GPS_H 0.5     # Relaxed GPS horizontal accuracy requirement
param set EKF2_REQ_HDRIFT 0.5    # Relaxed horizontal drift rate
param set EKF2_REQ_VDRIFT 0.5    # Relaxed vertical drift rate
param set EKF2_HGT_REF 1         # Use GPS for height reference (matches Gazebo)
param set EKF2_MAG_TYPE 1        # Heading fusion only - no GPS COG yaw resets
param set EKF2_MAG_CHECK 0       # Disable magnetometer strength check
param set EKF2_BARO_CTRL 1       # Enable barometer fusion
param set EKF2_GPS_CTRL 7        # Enable GPS lon/lat/alt/vel fusion

# Control allocator parameters for HIL
param set HIL_ACT_FUNC1 101
param set HIL_ACT_FUNC2 102
param set HIL_ACT_FUNC3 103
param set HIL_ACT_FUNC4 104
param set PWM_MAIN_FUNC1 101
param set PWM_MAIN_FUNC2 102
param set PWM_MAIN_FUNC3 103
param set PWM_MAIN_FUNC4 104

# Mavlink parameters
param set MAV_TYPE 2

# Autotune parameters
param set MC_AT_EN 1

# RC Mapping parameters
param set RC_MAP_PITCH 2
param set RC_MAP_ROLL 1
param set RC_MAP_THROTTLE 3
param set RC_MAP_YAW 4
param set RC_MAP_FLTMODE 6
param set RC_MAP_KILL_SW 7

# CBRK parameters (circuit breakers for HITL)
param set CBRK_SUPPLY_CHK 894281
param set CBRK_IO_SAFETY 22027   # Disable IO safety for HITL
param set COM_ARM_MAG_STR 0      # Disable mag strength check for arming
param set COM_ARM_EKF_POS 1.0    # Relaxed EKF position error threshold
param set COM_ARM_EKF_VEL 1.0    # Relaxed EKF velocity error threshold
param set COM_ARM_EKF_HGT 1.0    # Relaxed EKF height error threshold
param set COM_ARM_EKF_YAW 0.5    # Relaxed EKF yaw error threshold
param set COM_ARM_IMU_ACC 1.0    # Relaxed IMU accel consistency
param set COM_ARM_IMU_GYR 0.25   # Relaxed IMU gyro consistency

# Landing parameters
param set LND_FLIGHT_T_LO 483791313

param save
